<Window x:Class="FleetOrganizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Organizer"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Padding="16"
            BorderThickness="0,0,1,0"
            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4,8,4,22">
          <TextBlock Text="FLEET ORGANIZER"
                     FontWeight="SemiBold"
                     FontSize="17" />
          <TextBlock Text="Personal EVE fleet utility"
                     Margin="0,5,0,0"
                     Opacity="0.65" />
        </StackPanel>

        <StackPanel Grid.Row="1">
          <Button Style="{StaticResource NavigationButtonStyle}"
                  Content="Home"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Home" />
          <Button Style="{StaticResource NavigationButtonStyle}"
                  Content="Profiles"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Profiles" />
          <Button Style="{StaticResource NavigationButtonStyle}"
                  Content="Live Fleet"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Live Fleet" />
          <Button Style="{StaticResource NavigationButtonStyle}"
                  Content="Activity"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Activity" />
          <Button Style="{StaticResource NavigationButtonStyle}"
                  Content="Settings"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Settings" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="4,12,4,4">
          <TextBlock Text="{Binding ConfigurationStatus}"
                     TextWrapping="Wrap"
                     FontSize="12"
                     Opacity="0.72" />
          <TextBlock Text="{Binding SignedInCharacter}"
                     Margin="0,5,0,0"
                     TextWrapping="Wrap"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Opacity="0.82" />
          <Button Margin="0,12,0,0"
                  Padding="10,7"
                  Content="Open data folder"
                  Command="{Binding OpenDataFolderCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="32,24,32,28">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" LastChildFill="True">
        <Border DockPanel.Dock="Right"
                Padding="10,5"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
          <TextBlock Text="Secure sign-in build"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Border>
        <StackPanel>
          <TextBlock Text="{Binding SelectedPage}"
                     FontSize="30"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding PageSubtitle}"
                     Margin="0,6,0,0"
                     FontSize="14"
                     Opacity="0.68" />
        </StackPanel>
      </DockPanel>

      <Border Grid.Row="1" Margin="0,28,0,18">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding SelectedPage}" Value="Home">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="{Binding StatusTitle}"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusDetail}"
                       Margin="0,7,20,0"
                       TextWrapping="Wrap"
                       Opacity="0.72" />
          </StackPanel>
          <Button Grid.Column="1"
                  MinWidth="150"
                  Padding="14,9"
                  Content="Review settings"
                  Command="{Binding NavigateCommand}"
                  CommandParameter="Settings" />
        </Grid>
      </Border>

      <Grid Grid.Row="2">
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding SelectedPage}" Value="Home">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Ready in this foundation"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,16,0,7" Text="✓ Windows WPF application shell" />
            <TextBlock Margin="0,7" Text="✓ Local SQLite database and migrations" />
            <TextBlock Margin="0,7" Text="✓ DPAPI secret-protection service" />
            <TextBlock Margin="0,7" Text="✓ Profile domain validation" />
            <TextBlock Margin="0,7" Text="✓ Core and infrastructure test projects" />
            <TextBlock Margin="0,7" Text="✓ Local EVE developer configuration" />
            <TextBlock Margin="0,7" Text="✓ EVE SSO Authorization Code + PKCE" />
            <TextBlock Margin="0,7" Text="✓ JWT signature, audience, and scope validation" />
            <TextBlock Margin="0,7" Text="✓ Encrypted remembered authorization" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Next implementation slice"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,16,0,7" Text="1. Read-only current fleet detection" />
            <TextBlock Margin="0,7" Text="2. Cache/rate-aware ESI client" />
            <TextBlock Margin="0,7" Text="3. Live hierarchy and member view" />
            <TextBlock Margin="0,7" Text="4. Profile editor and roster resolution" />
            <TextBlock Margin="0,7" Text="5. Invite and placement operation engine" />
            <TextBlock Margin="0,16,0,0"
                       Text="No fleet writes are enabled yet."
                       FontWeight="SemiBold"
                       Foreground="{StaticResource WarningBrush}" />
          </StackPanel>
        </Border>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    Grid.RowSpan="2"
                    Margin="0,28,0,0"
                    VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Style>
          <Style TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding SelectedPage}" Value="Settings">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ScrollViewer.Style>

        <StackPanel>
          <Border Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock Text="EVE authorization"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding SignedInCharacter}"
                           Margin="0,10,0,0"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding AuthenticationMessage}"
                           Margin="0,7,24,0"
                           TextWrapping="Wrap"
                           Opacity="0.72" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          MinWidth="190"
                          VerticalAlignment="Center">
                <Button Padding="14,9"
                        Content="Sign in with EVE"
                        Command="{Binding SignInCommand}" />
                <Button Margin="0,8,0,0"
                        Padding="14,9"
                        Content="Sign out"
                        Command="{Binding SignOutCommand}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Margin="0,18,0,0" Style="{StaticResource CardStyle}">
            <StackPanel>
              <TextBlock Text="Developer application"
                         FontSize="17"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding ConfigurationStatus}"
                         Margin="0,14,0,0"
                         FontWeight="SemiBold" />
              <TextBlock Text="Only the public client ID is read from configuration. The developer secret is never needed by this desktop app."
                         Margin="0,7,0,0"
                         TextWrapping="Wrap"
                         Opacity="0.72" />

              <TextBlock Text="Registered callback"
                         Margin="0,18,0,0"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding RedirectUri}"
                         Margin="0,5,0,0"
                         FontFamily="Consolas"
                         TextWrapping="Wrap" />

              <TextBlock Text="Required scopes"
                         Margin="0,18,0,0"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding RequiredScopes}"
                         Margin="0,5,0,0"
                         FontFamily="Consolas"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="1"
              Grid.RowSpan="2"
              Margin="0,28,0,0">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding SelectedPage}" Value="Home">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
              <DataTrigger Binding="{Binding SelectedPage}" Value="Settings">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="This page is the next product milestone."
                     FontSize="20"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Secure EVE sign-in is now implemented; live fleet and profile features follow next."
                     Margin="0,9,0,0"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     Opacity="0.68" />
        </StackPanel>
      </Border>

      <DockPanel Grid.Row="3" Margin="2,18,2,0">
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding DatabasePath}"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="520"
                   FontSize="11"
                   Opacity="0.55" />
        <TextBlock Text="Local-only • no telemetry • no live ESI writes"
                   FontSize="11"
                   Opacity="0.55" />
      </DockPanel>
    </Grid>
  </Grid>
</Window>
